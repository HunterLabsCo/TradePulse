# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vite) environment variables — set these in Vercel project settings.
# Anything prefixed with VITE_ is bundled into the client and is PUBLIC. Never put
# secrets (service-role keys, API keys) behind a VITE_ prefix.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project — required for the app to load at all.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_publishable_key

# Solana wallet that receives Pro payments — REQUIRED for payments to work.
# If unset, every payment attempt throws. Must match RECEIVING_WALLET below.
VITE_RECEIVING_WALLET=your_solana_wallet_address

# Sentry error monitoring DSN — optional but recommended in production.
# https://sentry.io → Your Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=your_sentry_dsn_here
