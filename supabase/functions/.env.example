# ─────────────────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets. Set with:
#   supabase secrets set KEY=value
# These are SERVER-SIDE only and must never appear in the frontend / be committed.
#
# Note: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by the Supabase edge runtime — you do NOT need to set
# them manually. They are listed here only for reference.
# ─────────────────────────────────────────────────────────────────────────────

# Auto-injected by Supabase (reference only):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# Solana wallet that receives Pro payments — must match VITE_RECEIVING_WALLET.
# Required by verify-payment; if unset, all verification returns a 500.
RECEIVING_WALLET=your_solana_wallet_address

# Helius RPC API key — required by verify-payment to read on-chain transactions.
HELIUS_API_KEY=your_helius_api_key

# Anthropic API key — required by parse-trade-transcript (AI trade parsing).
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs API key — required by elevenlabs-scribe-token (voice transcription).
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Admin secret — required by admin-action; sent as the x-admin-secret header.
ADMIN_SECRET=your_long_random_admin_secret
